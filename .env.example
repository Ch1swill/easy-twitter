# ============================================================
# 本文件仅供本地开发参考（不使用 Docker 时）。
# Docker 用户请直接编辑 docker-compose.yaml 中的 environment。
# ============================================================

# [必填] Telegram Bot 令牌
BOT_TOKEN=your_telegram_bot_token_here

# [可选] 允许使用的 Telegram 用户 ID，逗号分隔（空=不限）
ALLOWED_USERS=

# [可选] 代理（同时用于 Telegram API 和 yt-dlp）
HTTP_PROXY=
HTTPS_PROXY=

# [可选] 自动点赞下载
AUTO_LIKES_ENABLED=false
AUTO_LIKES_TARGET_USER=
AUTO_LIKES_POLL_INTERVAL=300

# [可选] 下载完成后消息处理: minimal | delete
BOT_CLEANUP_MODE=minimal

# ------ 以下为高级选项，通常无需修改 ------

DOWNLOAD_DIR=/data/downloads
COOKIES_FILE=/secrets/cookies.txt
LOG_FILE=/data/logs/bot.log
SQLITE_PATH=/data/state/bot.db
AUTO_LIKES_MAX_PER_ROUND=20
AUTO_LIKES_QUEUE_MAXSIZE=200
AUTO_LIKES_WORKERS=2
AUTO_LIKES_RETRY_MAX=3
AUTO_LIKES_RETRY_BACKOFF_SEC=30
LIKES_GRAPHQL_QUERY_ID=RozQdCp4CilQzrcuU0NY5w
USER_GRAPHQL_QUERY_ID=xmU6X_CKVnQ5lSrCbAmJsg
