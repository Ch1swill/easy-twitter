# Required
BOT_TOKEN=your_telegram_bot_token_here

# Required for the app (path inside container is set in docker-compose.yaml)
DOWNLOAD_DIR=/data/downloads

# Optional: comma-separated Telegram user IDs (empty = allow all)
ALLOWED_USERS=

# Optional: proxy for Telegram API and yt-dlp
HTTP_PROXY=
HTTPS_PROXY=

# Optional: Netscape cookies file path (inside container when using compose)
COOKIES_FILE=/secrets/cookies.txt

# After successful download: minimal = short "done" text; delete = remove status message
BOT_CLEANUP_MODE=minimal

# Optional log path in container
LOG_FILE=/data/logs/bot.log

# Auto likes polling (single account)
AUTO_LIKES_ENABLED=false
AUTO_LIKES_TARGET_USER=
AUTO_LIKES_POLL_INTERVAL=300
AUTO_LIKES_MAX_PER_ROUND=20
AUTO_LIKES_QUEUE_MAXSIZE=200
AUTO_LIKES_WORKERS=2
AUTO_LIKES_RETRY_MAX=3
AUTO_LIKES_RETRY_BACKOFF_SEC=30

# SQLite state path in container
SQLITE_PATH=/data/state/bot.db
